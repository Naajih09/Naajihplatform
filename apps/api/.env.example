# ---- Database ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/naajih?schema=public
# DIRECT_URL=postgresql://postgres:password@localhost:5432/naajih?schema=public

# ---- JWT ----
JWT_SECRET=your-secret-key-change-in-production

# ---- Admin Seed ----
ADMIN_EMAIL=admin@naajih.com
ADMIN_PASSWORD=your-admin-password
ADMIN_SEED_SECRET=your-seed-secret-change-in-production
ALLOW_ADMIN_SEED=true

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Naajih <noreply@naajih.com>"

# ---- Email (Resend - preferred for production) ----
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=noreply@naajih.com

# ---- Email Verification ----
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_TTL_HOURS=24

# ---- Password Reset ----
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_EXPOSE_LINK=false

# ---- Beta / Dev Mode ----
BETA_TEST_MODE=false
ENABLE_SWAGGER=false

# ---- App URLs ----
APP_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGINS=

# ---- Certificate ----
CERT_LOGO_URL=
CERTIFICATE_TOKEN_MAX_AGE_DAYS=365
# CERTIFICATE_VERIFICATION_SECRET=

# ---- Payments (Paystack) ----
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=wh_xxxxxxxxxx

# ---- Payments (OPay) ----
# OPAY_SECRET_KEY=
# OPAY_MERCHANT_ID=
# OPAY_PUB_KEY=
# OPAY_WEBHOOK_SECRET=

# ---- Subscription ----
SUBSCRIPTION_AMOUNT_NGN=5000
ASPIRING_OWNER_SUBSCRIPTION_AMOUNT_NGN=5000
SUBSCRIPTION_DURATION_DAYS=30
TRIAL_DURATION_DAYS=14

# ---- Misc ----
API_PREFIX=api
PORT=3000
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb

# ---- Keep-Alive (for hosts that sleep) ----
# KEEP_ALIVE_URL=
